{
  "manifest_version": 3,
  "name": "AlgoSync",
  "description": "Automatically integrate your LeetCode & multi-platform coding submissions to GitHub",
  "homepage_url": "https://github.com/Aditya-0709/AlgoSync",
  "version": "__LH_VERSION__",
  "author": "Aditya Garg",
  "action": {
    "default_icon": "assets/thumbnail.png",
    "default_popup": "popup.html",
    "default_title": "AlgoSync - Upload your coding solutions to GitHub"
  },
  "icons": {
    "16": "assets/thumbnail.png",
    "48": "assets/thumbnail.png",
    "128": "assets/thumbnail.png"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "permissions": [
    "unlimitedStorage",
    "storage",
    "webNavigation"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://cn.leetcode.com/*",
        "https://practice.geeksforgeeks.org/*",
        "https://www.geeksforgeeks.org/*"
      ],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["scripts/github/authorize.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "host_permissions": [
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["scripts/gfg_code_extractor.js"],
      "matches": [
        "https://practice.geeksforgeeks.org/*",
        "https://www.geeksforgeeks.org/*",
        "https://geeksforgeeks.org/*"
      ]
    }
  ]
}
