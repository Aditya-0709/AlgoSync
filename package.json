{
  "name": "AlgoSync",
  "version": "2.0.9",
  "private": true,
  "description": "Automatically integrate your code from LeetCode and other platforms with GitHub using AlgoSync",
  "type": "module",
  "scripts": {
    "dev": "webpack --mode=production --watch",
    "setup": "npm i",
    "format": "prettier --write **/*.{js,jsx,ts,tsx,css,html}",
    "format-test": "prettier --check **/*.{js,jsx,ts,tsx,css,html}",
    "lint": "eslint **/*.{js,ts} --fix",
    "lint-test": "eslint **/*.{js,ts} --color",
    "build": "webpack --mode=production",
    "test": "jasmine"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.2.12",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "babel-loader": "^9.1.3",
    "chrome-types": "^0.1.282",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "filemanager-webpack-plugin": "^8.0.0",
    "ignore-loader": "^0.1.2",
    "jasmine": "^5.1.0",
    "postcss": "^8.4.38",
    "postcss-loader": "^8.1.1",
    "prettier": "^2.2.1",
    "puppeteer": "^22.11.2",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.4",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.4"
  }
}
